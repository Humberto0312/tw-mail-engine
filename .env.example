# ─── tw-mail-engine · variables de entorno ───
# Copia a .env para desarrollo local. En Coolify se cargan como env vars.

# Mongo (MISMA base que api-matrix: el motor LEE config de dominios/tenants
# y ESCRIBE el estado de cada mensaje). La DB se extrae del URI si no se pasa.
MONGO_URI=
MONGO_DB=

# HTTP API del motor
PORT=8080
LOG_LEVEL=info

# Identidad del nodo de envío (debe coincidir con el rDNS de la IP)
ENGINE_HOSTNAME=mta1.twilbox.com

# Token compartido: api-matrix lo manda en Authorization: Bearer <token>.
# Sin esto, nadie puede pedirle al motor que envíe. OBLIGATORIO.
ENGINE_API_TOKEN=

# IPs de salida del MTA, separadas por coma. Vacío = usa la IP por defecto
# del servidor. Diseñado para crecer a pool multi-IP (IP dedicada por cliente).
SEND_IPS=

# Pool de workers que entregan en paralelo
WORKER_POOL_SIZE=8

# Reintentos de entrega ante fallos temporales (soft bounce)
MAX_DELIVERY_RETRIES=4

# Webhook de vuelta a api-matrix para reportar entregas/rebotes/quejas
BOUNCE_WEBHOOK_URL=

# Selector DKIM por defecto (parte del registro DNS: <selector>._domainkey.dominio)
DKIM_SELECTOR=twmail
